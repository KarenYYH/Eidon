# ── LLM（翻译 / 口播稿改写 / 创作脚本）— OpenAI 兼容接口 ──
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# ── Whisper 语音转写 ──
WHISPER_MODEL=base                # tiny / base / small / medium / large

# ── TTS 配音 ──
TTS_PROVIDER=edge                 # edge（免费）| cosyvoice（声音克隆）
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 字幕烧录字体（须为已安装的字体名）
# Linux: "Noto Sans CJK SC"   macOS: "Heiti SC"
SUBTITLE_FONT=Noto Sans CJK SC

# ── CosyVoice2 声音克隆（独立 GPU 服务，可选）──
COSYVOICE_HOST=http://localhost:50000
COSYVOICE_SAMPLE_RATE=24000

# ── HeyGem 数字人口型（独立 Docker/GPU 服务，可选）──
HEYGEM_HOST=http://localhost:8383
HEYGEM_POLL_INTERVAL=3.0
HEYGEM_TIMEOUT=1800.0

# ── 在线素材自动下载（创作模式，可选；免费注册拿 key）──
STOCK_ENABLED=false
STOCK_PROVIDER=pexels             # pexels | pixabay
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── 多平台一键发布（可选；upload-post.com）──
UPLOAD_POST_API_KEY=
UPLOAD_POST_HOST=https://api.upload-post.com

DEBUG=false
