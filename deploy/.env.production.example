# ── Eidon 生产环境配置（Linux GPU 服务器，全部本机）─────────────────────────
# 拷到 backend/.env 后按需修改

# LLM（口播稿转写/翻译/改写）— 走云端 DeepSeek，不占本地硬件
LLM_API_KEY=填你的key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# Whisper 转写模型（GPU 机器可用更大模型，质量更高）
# tiny/base/small/medium/large-v3 —— 有 GPU 建议 small 或 medium
WHISPER_MODEL=small

# TTS 引擎：edge（免费云）| cosyvoice（本机声音克隆）
TTS_PROVIDER=edge
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 字幕烧录字体 —— Linux 必须用已安装的中文字体，否则中文显示为方框。
# setup.sh 会安装 Noto Sans CJK；如换字体请确保 fc-list 能查到。
SUBTITLE_FONT=Noto Sans CJK SC

# 在线素材自动下载（AI 创作模式补素材，可选）。申请见 README 3.5-A。
# STOCK_PROVIDER 二选一：pexels | pixabay
STOCK_ENABLED=false
STOCK_PROVIDER=pexels
PEXELS_API_KEY=
PIXABAY_API_KEY=

# 多平台自动发布（可选）。申请见 README 3.5-B。
UPLOAD_POST_API_KEY=

# CosyVoice2 与 HeyGem 都在本机 → 指向 localhost
COSYVOICE_HOST=http://127.0.0.1:50000
COSYVOICE_SAMPLE_RATE=24000

HEYGEM_HOST=http://127.0.0.1:8383
HEYGEM_POLL_INTERVAL=3.0
HEYGEM_TIMEOUT=1800.0

DEBUG=false
