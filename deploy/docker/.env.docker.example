# ── Eidon Docker Compose 环境配置 ───────────────────────────────────────────
# 用法：复制本文件为同目录的 .env，填好 LLM_API_KEY 后 docker compose up -d
#   cp .env.docker.example .env
# compose 会通过 env_file 注入 backend 容器。

# ── LLM（翻译 / 口播稿改写 / 创作脚本）— OpenAI 兼容接口，必填 ──
LLM_API_KEY=填你的key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# ── Whisper 语音转写（首次转写会下模型到 whisper-cache 卷，一次性）──
WHISPER_MODEL=small               # tiny / base / small / medium / large

# ── TTS 配音 ──
# Phase 1 用 edge（免费云）。声音克隆 cosyvoice 需 Phase 3 部署后才可选。
TTS_PROVIDER=edge
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# 字幕烧录字体 —— 容器内已装 Noto CJK，保持此值
SUBTITLE_FONT=Noto Sans CJK SC

# ── 在线素材自动下载（创作模式，可选；免费注册拿 key）──
STOCK_ENABLED=false
STOCK_PROVIDER=pexels             # pexels | pixabay
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── 多平台一键发布（可选；upload-post.com）──
UPLOAD_POST_API_KEY=
UPLOAD_POST_HOST=https://api.upload-post.com

# ── 下面两项 Phase 1 用不到，部署了对应服务再启用 ──
# 数字人(HeyGem，Phase 2)：用 compose 服务名互访
# HEYGEM_HOST=http://heygem:8383
# HEYGEM_POLL_INTERVAL=3.0
# HEYGEM_TIMEOUT=1800.0
# 声音克隆(CosyVoice，Phase 3)：
# COSYVOICE_HOST=http://cosyvoice:50000
# COSYVOICE_SAMPLE_RATE=24000

DEBUG=false
